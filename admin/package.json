{
  "name": "@qingxier/admin",
  "version": "2.0.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "rm -rf dist coverage",
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:ci": "vitest run --coverage --reporter=default --reporter=junit --outputFile=../reports/admin-junit.xml"
  },
  "dependencies": {
    "@qingxier/contracts": "2.0.0",
    "element-plus": "^2.14.3",
    "pinia": "2.3.1",
    "vue": "3.5.40",
    "vue-router": "4.5.0"
  },
  "devDependencies": {
    "@types/node": "22.18.6",
    "@vitejs/plugin-vue": "5.2.4",
    "@vitest/coverage-v8": "2.1.9",
    "@vue/test-utils": "2.4.6",
    "jsdom": "25.0.1",
    "typescript": "5.8.3",
    "vite": "5.4.14",
    "vitest": "2.1.9",
    "vue-tsc": "2.2.8"
  }
}
