APP_ENV=prod
APP_VERSION=1.2.0
LOG_LEVEL=INFO
JWT_SECRET=replace-with-at-least-32-random-bytes
JWT_ISSUER=qingxier
ADMIN_REQUIRE_MFA=true

STORAGE_BACKEND=mongo
MONGO_URI=mongodb://mongo:27017/qingxier
MONGO_DATABASE=qingxier

EVENT_BACKEND=mqtt
MQTT_URL=mqtt://emqx:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TLS=false

SPEECH_PROVIDER_MODE=dashscope
DASHSCOPE_API_KEY=
DASHSCOPE_REGION=beijing
DASHSCOPE_ASR_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/inference
DASHSCOPE_COSYVOICE_URL=https://dashscope.aliyuncs.com/api/v1/services/audio/tts/SpeechSynthesizer
DASHSCOPE_QWEN_TTS_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
COSYVOICE_MODEL=cosyvoice-v3.5-flash
COSYVOICE_SINGAPORE_MODEL=cosyvoice-v3-flash
QWEN_SYSTEM_TTS_MODEL=qwen3-tts-flash
QWEN_SYSTEM_VOICE=Cherry
TTS_FALLBACK_ENABLED=true

LLM_MODE=openai-compatible
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-chat

SPEECH_WS_BASE_URL=wss://voice.example.com/ws/v1/voice
DIALECT_HIGH_THRESHOLD=0.75
DIALECT_MEDIUM_THRESHOLD=0.55
WAKE_WORD=阿西
WAKE_MODEL_FAMILY=WakeNet9
WAKE_MODEL_VERSION=wakenet9-axi-1.0.0
WAKE_THRESHOLD=0.72
